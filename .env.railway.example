# ============================================================
# Railway Environment Variables Template
# Copy these into Railway: Settings → Variables
# ============================================================

# ── Required: Bayse API Credentials ────────────────────────
BAYSE_PUBLIC_KEY=pk_live_YOUR_KEY_HERE
BAYSE_SECRET_KEY=sk_live_YOUR_SECRET_HERE
BAYSE_BASE_URL=https://relay.bayse.markets

# ── Currency (match your Bayse account type) ───────────────
# Set to NGN if you have a Naira account, USD otherwise
CURRENCY=NGN

# ── Capital ────────────────────────────────────────────────
# Set the one that matches your CURRENCY above
CAPITAL_NGN=400000
CAPITAL_USD=250

# ── Bot Mode ───────────────────────────────────────────────
# true = paper trading (safe), false = real money
DRY_RUN=true

# ── Server Port ────────────────────────────────────────────
# Leave this blank — Railway sets PORT automatically
# PORT is auto-injected by Railway, do NOT set it manually

# ── Optional: Binance (for BTC/ETH trend signals) ──────────
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=
